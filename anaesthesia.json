[{"id":3966,"text":"A patient was given halothane for general anesthesia. He developed rigidity, and hyperthermia. These symptoms are most likely due to which ion?","opts":[{"l":"A","t":"Na+ \u200b\u200b\u200b\u200b\u200b\u200b\u200b","c":false},{"l":"B","t":"Ca2+ \u200b\u200b\u200b\u200b\u200b\u200b\u200b","c":true},{"l":"C","t":"K+ \u200b\u200b\u200b\u200b\u200b\u200b\u200b","c":false},{"l":"D","t":"CI-","c":false}],"ans":"B","exp":"<p><strong>Ans. B. Ca2+</strong></p>\n<p>@dams_new_robot</p>","qi":[],"ei":[],"subj":"Anaesthesia","topic":"General","exam":"FMGE June 2021 - 2021-06-18","etype":"FMGE","year":2021}]